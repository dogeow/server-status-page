{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "status-page/laravel-probe",
    "description": "A fail-open Laravel probe for readiness, queue canaries, scheduler heartbeats, and end-to-end Reverb checks.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "health-check",
        "laravel",
        "monitoring",
        "queue",
        "reverb",
        "scheduler"
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5",
        "illuminate/broadcasting": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/bus": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/cache": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/queue": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "StatusPage\\LaravelProbe\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "StatusPage\\LaravelProbe\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "StatusPage\\LaravelProbe\\StatusProbeServiceProvider"
            ],
            "aliases": {
                "StatusProbe": "StatusPage\\LaravelProbe\\Facades\\StatusProbe"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
